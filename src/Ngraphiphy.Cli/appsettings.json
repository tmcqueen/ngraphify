{
  "Providers": {
    "Anthropic": {
      "ApiType": "anthropic",
      "ApiKey": "pass://anthropic/api-key",
      "Model": "claude-sonnet-4-6",
      "MaxTokens": 4096
    },
    "OpenAI": {
      "ApiType": "openai",
      "ApiKey": "pass://openai/api-key",
      "Model": "gpt-4o"
    },
    "Ollama": {
      "ApiType": "ollama",
      "Endpoint": "http://localhost:11434",
      "Model": "llama3.2"
    },
    "GitHubCopilot": {
      "ApiType": "copilot"
    },
    "A2A": {
      "ApiType": "a2a",
      "Endpoint": "env://A2A_AGENT_URL",
      "ApiKey": ""
    },
    "CloudflareAI": {
      "ApiType": "openai",
      "Endpoint": "https://api.cloudflare.com/client/v4/accounts/{account_id}/ai/v1/",
      "ApiKey": "pass://cloudflare/api-token",
      "Model": "@cf/baai/bge-base-en-v1.5",
      "Dimensions": 768
    }
  },
  "Llm": {
    "Provider": "Anthropic"
  },
  "Embedding": {
    "Provider": "CloudflareAI"
  },
  "GraphDatabase": {
    "Backend": "neo4j",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "pass://databases/neo4j/password"
    },
    "Memgraph": {
      "Host": "localhost",
      "Port": 7688
    }
  }
}
