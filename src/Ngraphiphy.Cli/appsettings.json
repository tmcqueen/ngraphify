{
  "Llm": {
    "Provider": "anthropic",
    "Anthropic": {
      "ApiKey": "pass://anthropic/api-key",
      "Model": "claude-sonnet-4-6"
    },
    "OpenAi": {
      "ApiKey": "pass://openai/api-key"
    },
    "Ollama": {
      "Model": "llama3.2",
      "Endpoint": "http://localhost:11434"
    },
    "A2A": {
      "AgentUrl": "env://A2A_AGENT_URL"
    }
  },
  "GraphDatabase": {
    "Backend": "neo4j",
    "Neo4j": {
      "Uri": "bolt://localhost:7687",
      "Username": "neo4j",
      "Password": "pass://databases/neo4j/password"
    },
    "Memgraph": {
      "Host": "localhost",
      "Port": 7687
    }
  },
  "Embedding": {
    "Cloudflare": {
      "AccountId": "pass://cloudflare/account-id",
      "ApiToken": "pass://cloudflare/api-token",
      "Model": "@cf/baai/bge-base-en-v1.5"
    }
  }
}
